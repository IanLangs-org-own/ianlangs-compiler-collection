#std io

template <typename T = int>
tagged union[2] result<T, void> {Ok, Err}

using namespace flow;

type int_result = result<int>;

fn main() -> int {
    int_result r;

    r = result<int>::Err;

    switch (r) {
        case int_result::Ok:
            println("Ok = ", r.value.Ok);
            break;
        case int_result::Err:
            println("Err");
            break;
    }

    return 0;
}