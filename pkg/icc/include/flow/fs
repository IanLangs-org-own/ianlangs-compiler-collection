#pragma once
#include <string>
#include <fstream>
#include <sstream>
#include <flow/types>
namespace flow {

    class File {
        flow::str path;

    public:
        explicit File(const flow::str& p) : path(p) {}

        flow::str read() const {
            std::ifstream f(path);
            if (!f) return "";
            std::ostringstream ss;
            ss << f.rdbuf();
            f.close();
            return ss.str();
        }

        void write(const flow::str& data) const {
            std::ofstream f(path, std::ios::trunc);
            if (!f) return;
            f << data;
            f.close();
        }

        void append(const flow::str& data) const {
            std::ofstream f(path, std::ios::app);
            if (!f) return;
            f << data;
            f.close();
        }
    };

    inline File openFile(const flow::str& path) {
        return File(path);
    }

}
