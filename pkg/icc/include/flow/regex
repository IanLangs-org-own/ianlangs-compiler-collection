#pragma once
#include <regex>
#include <string>
#include <vector>
#include <flow/types>
namespace flow {

    // ---------- match ----------
    inline bool re_match(const flow::str& pat, const flow::str& s) {
        return std::regex_match(s, std::regex(pat));
    }

    inline bool re_match(const flow::str& pat,
                         const flow::str& s,
                         std::smatch& m) {
        return std::regex_match(s, m, std::regex(pat));
    }

    // ---------- search ----------
    inline bool re_search(const flow::str& pat, const flow::str& s) {
        return std::regex_search(s, std::regex(pat));
    }

    inline bool re_search(const flow::str& pat,
                          const flow::str& s,
                          std::smatch& m) {
        return std::regex_search(s, m, std::regex(pat));
    }

    // ---------- findall ----------
    inline std::vector<flow::str>
    re_findall(const flow::str& pat, const flow::str& s) {
        std::vector<flow::str> out;
        std::regex r(pat);

        for (std::sregex_iterator it(s.begin(), s.end(), r);
             it != std::sregex_iterator{};
             ++it) {
            out.push_back(it->str());
        }
        return out;
    }

    // ---------- sub ----------
    inline flow::str
    re_sub(const flow::str& pat,
           const flow::str& repl,
           const flow::str& s) {
        return std::regex_replace(s, std::regex(pat), repl);
    }

}
